# Copy to .env (same folder as docker-compose.yml) and fill in.
# docker compose reads it automatically; never commit the real .env.

# Your timezone (IANA name) — without it the container runs on UTC and all
# displayed times (weather, clock, charts) are off.
TZ=America/New_York
# Labby login. Leave the password empty to run without a login screen (open on your LAN).
LABBY_AUTH_USERNAME=labby
LABBY_AUTH_PASSWORD=

# Optional webhook for service down/recovery alerts.
# ntfy: https://ntfy.sh/your-topic — Discord/Slack: paste the webhook URL.
LABBY_ALERT_WEBHOOK=

# Optional Pushover push notifications (create an application at pushover.net/apps/build
# for the token; your user key is on the pushover.net dashboard). Set both to enable.
LABBY_PUSHOVER_TOKEN=
LABBY_PUSHOVER_USER=

# Good-morning digest hour (0-23), e.g. 8; empty = off
LABBY_DIGEST_HOUR=

QNAP_HOST=192.168.1.50
QNAP_PORT=8080
QNAP_USE_HTTPS=false
QNAP_USERNAME=labby
QNAP_PASSWORD=
AMBIENT_API_KEY=
AMBIENT_APP_KEY=
AMBIENT_DEVICE_MAC=

# Kontainr (embedded on the Containers page). The URL is loaded by YOUR BROWSER,
# so use the machine's LAN IP if you access Labby from other devices.
KONTAINR_URL=http://localhost:5124
KONTAINR_AUTH_USERNAME=
KONTAINR_AUTH_PASSWORD=

# Optional web terminal (e.g. a web-SSH container) embedded on the Terminal page.
# Browser-loaded iframe URL, so it must resolve from your devices.
TERMINAL_URL=

# Optional OSINT Hub (github.com/chrisdfennell/OSINT) embedded on the OSINT page.
# Browser-loaded iframe URL, so it must resolve from your devices, e.g. http://nas:3000
OSINT_URL=

# Media page (all optional — configured sources get a card, the rest are hidden).
PLEX_BASE_URL=
PLEX_TOKEN=
TAUTULLI_BASE_URL=
TAUTULLI_API_KEY=
SONARR_BASE_URL=
SONARR_API_KEY=
RADARR_BASE_URL=
RADARR_API_KEY=
OVERSEERR_BASE_URL=
OVERSEERR_API_KEY=
QBITTORRENT_BASE_URL=
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=
NZBGET_BASE_URL=
NZBGET_USERNAME=
NZBGET_PASSWORD=
PROWLARR_BASE_URL=
PROWLARR_API_KEY=
