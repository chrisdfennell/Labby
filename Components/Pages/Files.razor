@page "/files"
@rendermode InteractiveServer
@inject QnapFileStation FileStation
@inject ShareLinkService ShareLinks
@inject NavigationManager Nav
@inject IJSRuntime Js

<PageTitle>Labby — Files</PageTitle>

<h1 class="mb-4">📁 NAS Files</h1>

@if (!FileStation.IsConfigured)
{
    <div class="alert alert-warning">
        QNAP is not configured. Set <code>Qnap:Host</code>, <code>Qnap:Username</code> and <code>Qnap:Password</code> first.
    </div>
}
else
{
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                @if (_segments.Count == 0)
                {
                    <span>Shares</span>
                }
                else
                {
                    <button type="button" class="link-btn" @onclick="() => NavigateToDepthAsync(0)">Shares</button>
                }
            </li>
            @for (var i = 0; i < _segments.Count; i++)
            {
                var depth = i + 1;
                if (depth == _segments.Count)
                {
                    <li class="breadcrumb-item active" aria-current="page">@_segments[i]</li>
                }
                else
                {
                    <li class="breadcrumb-item">
                        <button type="button" class="link-btn" @onclick="() => NavigateToDepthAsync(depth)">@_segments[i]</button>
                    </li>
                }
            }
        </ol>
    </nav>

    @if (_segments.Count > 0)
    {
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3 files-toolbar">
            <label class="btn btn-sm btn-outline-primary mb-0 @(_uploading ? "disabled" : "")">
                @(_uploading ? $"⏳ uploading {_uploadName}…" : "⬆️ Upload file")
                <InputFile OnChange="UploadAsync" disabled="@_uploading" hidden />
            </label>
            @if (_creatingFolder)
            {
                <input class="form-control form-control-sm files-newfolder" placeholder="folder name"
                       @bind="_newFolderName" @bind:event="oninput" />
                <button class="btn btn-sm btn-outline-primary" @onclick="CreateFolderAsync"
                        disabled="@(string.IsNullOrWhiteSpace(_newFolderName))">create</button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => _creatingFolder = false">cancel</button>
            }
            else
            {
                <button class="btn btn-sm btn-outline-primary" @onclick="() => _creatingFolder = true">📁 New folder</button>
            }
            @if (_actionError is not null)
            {
                <span class="text-danger small">✗ @_actionError</span>
            }
        </div>
    }

    @if (_error is not null)
    {
        <div class="alert alert-danger">@_error</div>
    }
    else if (_loading)
    {
        <p class="text-muted">Loading…</p>
    }
    else if (_entries.Count == 0)
    {
        <p class="text-muted">This folder is empty.</p>
    }
    else
    {
        <table class="table table-hover align-middle">
            <thead>
                <tr><th>Name</th><th class="text-end">Size</th><th class="text-end">Modified</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var entry in _entries)
                {
                    <tr>
                        <td>
                            @if (entry.IsFolder)
                            {
                                <button type="button" class="link-btn" @onclick="() => OpenFolderAsync(entry.Name)">
                                    📁 @entry.Name
                                </button>
                            }
                            else
                            {
                                <span>📄 @entry.Name</span>
                            }
                        </td>
                        <td class="text-end text-muted">@(entry.IsFolder ? "—" : Format.Bytes(entry.SizeBytes))</td>
                        <td class="text-end text-muted">@(entry.Modified?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                        <td class="text-end text-nowrap">
                            @if (!entry.IsFolder)
                            {
                                @if (PreviewKind(entry.Name) != Preview.None)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" title="Preview"
                                            @onclick="() => TogglePreview(entry)">@(_previewFor == entry.Name ? "▲" : "👁")</button>
                                }
                                <a class="btn btn-sm btn-outline-primary"
                                   href="/api/files/download?path=@Uri.EscapeDataString(CurrentPath)&name=@Uri.EscapeDataString(entry.Name)"
                                   target="_blank" rel="noreferrer">Download</a>
                                <button class="btn btn-sm btn-outline-secondary" title="Create a 7-day share link"
                                        @onclick="() => ShareAsync(entry)">🔗</button>
                            }
                            <button class="btn btn-sm btn-outline-secondary" title="Rename"
                                    @onclick="() => BeginAction(entry, RowAction.Rename)">✏️</button>
                            <button class="btn btn-sm btn-outline-secondary" title="Move"
                                    @onclick="() => BeginAction(entry, RowAction.Move)">📦</button>
                            @if (_confirmDelete == entry.Name)
                            {
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteAsync(entry)">confirm delete</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger" title="Delete"
                                        @onclick="() => _confirmDelete = entry.Name">🗑</button>
                            }
                        </td>
                    </tr>
                    @if (_actionFor == entry.Name && _action != RowAction.None)
                    {
                        <tr>
                            <td colspan="4" class="files-action-row">
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    @if (_action == RowAction.Rename)
                                    {
                                        <span class="text-muted small">rename to</span>
                                        <input class="form-control form-control-sm files-newfolder" @bind="_actionValue" @bind:event="oninput" />
                                        <button class="btn btn-sm btn-outline-primary" disabled="@string.IsNullOrWhiteSpace(_actionValue)"
                                                @onclick="() => RenameAsync(entry)">rename</button>
                                    }
                                    else if (_action == RowAction.Move)
                                    {
                                        <span class="text-muted small">move to folder</span>
                                        <input class="form-control form-control-sm files-newfolder" style="width:22rem" @bind="_actionValue" @bind:event="oninput" />
                                        <button class="btn btn-sm btn-outline-primary" disabled="@string.IsNullOrWhiteSpace(_actionValue)"
                                                @onclick="() => MoveAsync(entry)">move</button>
                                    }
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelAction">cancel</button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (_previewFor == entry.Name)
                    {
                        var src = $"/api/files/download?path={Uri.EscapeDataString(CurrentPath)}&name={Uri.EscapeDataString(entry.Name)}&inline=true";
                        <tr>
                            <td colspan="4" class="files-preview">
                                @switch (PreviewKind(entry.Name))
                                {
                                    case Preview.Image:
                                        <img src="@src" alt="@entry.Name" />
                                        break;
                                    case Preview.Video:
                                        <video src="@src" controls preload="metadata"></video>
                                        break;
                                    case Preview.Audio:
                                        <audio src="@src" controls preload="metadata"></audio>
                                        break;
                                    case Preview.Frame:
                                        <iframe src="@src" title="@entry.Name" sandbox=""></iframe>
                                        break;
                                }
                            </td>
                        </tr>
                    }
                    @if (_shareUrlFor == entry.Name && _shareUrl is not null)
                    {
                        <tr>
                            <td colspan="4" class="files-action-row">
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    <span class="text-muted small">7-day link</span>
                                    <input class="form-control form-control-sm files-sharelink" readonly value="@_shareUrl" />
                                    <button class="btn btn-sm btn-outline-primary" @onclick="CopyShareUrlAsync">@(_copied ? "copied ✓" : "copy")</button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => _shareUrlFor = null">close</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
}

@code {
    // Blazor's SignalR file streaming handles this fine; QTS is the ceiling.
    private const long MaxUploadBytes = 2L * 1024 * 1024 * 1024;

    private readonly List<string> _segments = [];
    private IReadOnlyList<FileEntry> _entries = [];
    private bool _loading = true;
    private string? _error;
    private bool _uploading;
    private string? _uploadName;
    private bool _creatingFolder;
    private string _newFolderName = "";
    private string? _actionError;

    private string CurrentPath => "/" + string.Join('/', _segments);

    private async Task UploadAsync(InputFileChangeEventArgs e)
    {
        _actionError = null;
        _uploading = true;
        _uploadName = e.File.Name;
        try
        {
            await using var stream = e.File.OpenReadStream(MaxUploadBytes);
            await FileStation.UploadAsync(CurrentPath, e.File.Name, stream);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _actionError = ex.GetBaseException().Message;
        }
        finally
        {
            _uploading = false;
            _uploadName = null;
        }
    }

    private async Task CreateFolderAsync()
    {
        _actionError = null;
        try
        {
            await FileStation.CreateFolderAsync(CurrentPath, _newFolderName.Trim());
            _creatingFolder = false;
            _newFolderName = "";
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _actionError = ex.GetBaseException().Message;
        }
    }

    private enum Preview { None, Image, Video, Audio, Frame }

    private string? _previewFor;

    private static Preview PreviewKind(string name) =>
        Path.GetExtension(name).ToLowerInvariant() switch
        {
            ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp" or ".svg" or ".bmp" or ".avif" => Preview.Image,
            ".mp4" or ".webm" or ".m4v" or ".mov" or ".mkv" => Preview.Video,
            ".mp3" or ".m4a" or ".flac" or ".wav" or ".ogg" or ".opus" => Preview.Audio,
            ".pdf" or ".txt" or ".md" or ".log" or ".json" or ".xml" or ".yaml" or ".yml"
                or ".conf" or ".ini" or ".sh" or ".ps1" or ".cs" or ".js" or ".ts" or ".py"
                or ".css" or ".html" or ".htm" or ".csv" => Preview.Frame,
            _ => Preview.None,
        };

    private void TogglePreview(FileEntry entry) =>
        _previewFor = _previewFor == entry.Name ? null : entry.Name;

    private enum RowAction { None, Rename, Move }

    private RowAction _action = RowAction.None;
    private string? _actionFor;
    private string _actionValue = "";
    private string? _confirmDelete;
    private string? _shareUrlFor;
    private string? _shareUrl;
    private bool _copied;

    private void BeginAction(FileEntry entry, RowAction action)
    {
        _action = action;
        _actionFor = entry.Name;
        _actionValue = action == RowAction.Rename ? entry.Name : CurrentPath;
        _confirmDelete = null;
        _shareUrlFor = null;
    }

    private void CancelAction()
    {
        _action = RowAction.None;
        _actionFor = null;
        _confirmDelete = null;
    }

    private Task RenameAsync(FileEntry entry) =>
        RunRowActionAsync(() => FileStation.RenameAsync(CurrentPath, entry.Name, _actionValue.Trim()));

    private Task MoveAsync(FileEntry entry) =>
        RunRowActionAsync(() => FileStation.MoveAsync(CurrentPath, entry.Name, _actionValue.Trim()));

    private Task DeleteAsync(FileEntry entry) =>
        RunRowActionAsync(() => FileStation.DeleteAsync(CurrentPath, entry.Name));

    private async Task RunRowActionAsync(Func<Task> action)
    {
        _actionError = null;
        try
        {
            await action();
            CancelAction();
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _actionError = ex.GetBaseException().Message;
        }
    }

    private void ShareAsync(FileEntry entry)
    {
        var token = ShareLinks.CreateToken(CurrentPath, entry.Name, TimeSpan.FromDays(7));
        _shareUrl = $"{Nav.BaseUri}share/{token}";
        _shareUrlFor = entry.Name;
        _copied = false;
        _action = RowAction.None;
        _actionFor = null;
    }

    private async Task CopyShareUrlAsync()
    {
        try
        {
            await Js.InvokeVoidAsync("navigator.clipboard.writeText", _shareUrl);
            _copied = true;
        }
        catch (Exception)
        {
            // Clipboard needs a secure context; the readonly input is the fallback.
        }
    }

    // Runs after first render so prerendering never blocks on a slow/unreachable NAS.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;
        await RefreshAsync();
        StateHasChanged();
    }

    private async Task OpenFolderAsync(string name)
    {
        _segments.Add(name);
        await RefreshAsync();
    }

    private async Task NavigateToDepthAsync(int depth)
    {
        _segments.RemoveRange(depth, _segments.Count - depth);
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        if (!FileStation.IsConfigured)
            return;
        _loading = true;
        _error = null;
        _previewFor = null;
        try
        {
            _entries = _segments.Count == 0
                ? await FileStation.GetSharesAsync()
                : await FileStation.ListFolderAsync(CurrentPath);
        }
        catch (Exception ex)
        {
            _error = ex.GetBaseException().Message;
            _entries = [];
        }
        finally
        {
            _loading = false;
        }
    }
}
