@page "/terminal"
@using Microsoft.Extensions.Options
@inject IOptions<TerminalOptions> Config

<PageTitle>Labby — Terminal</PageTitle>

<div class="d-flex align-items-center flex-wrap gap-3 mb-4">
    <h1 class="mb-0">🖥️ Terminal</h1>
    @if (Config.Value.IsConfigured)
    {
        <a class="btn btn-sm btn-outline-secondary ms-auto" href="@Config.Value.Url" target="_blank" rel="noreferrer">
            Open in new tab ↗
        </a>
    }
</div>

@if (!Config.Value.IsConfigured)
{
    <div class="alert alert-warning">
        No terminal configured — set <code>Terminal:Url</code> (env <code>TERMINAL_URL</code>) to a browser-reachable
        web terminal, e.g. a web-SSH container.
    </div>
}
else
{
    <div class="kontainr-frame-wrap">
        <iframe src="@Config.Value.Url" title="Web terminal" class="kontainr-frame"></iframe>
    </div>
}
