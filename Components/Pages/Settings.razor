@page "/settings"
@rendermode InteractiveServer
@using Microsoft.Extensions.Options
@inject AlertNotifier Alerts
@inject MetricsStore Metrics
@inject BackupService Backups
@inject UpdateService Updates
@inject DigestService Digest
@inject IOptions<BackupOptions> BackupConfig
@inject IJSRuntime Js

<PageTitle>Labby — Settings</PageTitle>

<h1 class="mb-4">⚙️ Settings</h1>

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">🎨 Accent theme</div>
            <div class="card-body">
                <p class="text-muted small">Per-browser; applies instantly.</p>
                <div class="d-flex gap-2 flex-wrap">
                    @foreach (var (name, color) in Themes)
                    {
                        <button type="button" class="theme-swatch @(name == _theme ? "active" : "")"
                                style="--swatch: @color" title="@name" @onclick="() => SetThemeAsync(name)">
                            @name
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">🔔 Alerts</div>
            <div class="card-body">
                @if (!Alerts.IsEnabled)
                {
                    <p class="text-muted small mb-2">
                        No channel configured — set <code>LABBY_ALERT_WEBHOOK</code> and/or
                        <code>LABBY_PUSHOVER_TOKEN</code> + <code>LABBY_PUSHOVER_USER</code> in <code>.env</code>.
                    </p>
                }
                <button class="btn btn-sm btn-outline-primary" disabled="@(!Alerts.IsEnabled || _testSending)"
                        @onclick="SendTestAsync">
                    @(_testSending ? "sending…" : _testSent ? "sent ✓ — check your phone" : "🧪 Send test alert")
                </button>
                <hr class="my-2" />
                <button class="btn btn-sm btn-outline-secondary" disabled="@(!Alerts.IsEnabled || _digestSending)"
                        @onclick="SendDigestAsync">
                    @(_digestSending ? "sending…" : "☀️ Send digest now")
                </button>
                <hr class="my-2" />
                @if (_snoozedUntil is { } until)
                {
                    <p class="small mb-2"><span class="state-warn">🔇 Snoozed until @until.ToString("MMM d · HH:mm")</span> — alerts are logged but not delivered.</p>
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => ResumeAsync()">🔔 Resume alerts</button>
                }
                else
                {
                    <p class="text-muted small mb-2">Doing maintenance? Snooze deliveries (history still records everything):</p>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => SnoozeAsync(1)">1h</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => SnoozeAsync(4)">4h</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => SnoozeAsync(24)">24h</button>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">💾 Backup</div>
            <div class="card-body">
                <p class="text-muted small">
                    One SQLite file holds all history, metrics, and notes.
                    @if (BackupConfig.Value.SharePath is { Length: > 0 } share)
                    {
                        <span>Scheduled copy to <code>@share</code> every @BackupConfig.Value.Days days
                        (last: @(Backups.LastBackupAt?.ToString("MMM d · HH:mm") ?? "not yet")@(Backups.LastError is { } err ? $" — failed: {err}" : "")).</span>
                    }
                    else
                    {
                        <span>Set <code>Backup:SharePath</code> for scheduled copies to a NAS share.</span>
                    }
                </p>
                <a class="btn btn-sm btn-outline-primary" href="/api/backup" target="_blank">⬇ Download backup now</a>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-header">🚀 Updates</div>
            <div class="card-body">
                <p class="text-muted small mb-2">
                    Running version: <code>@(Updates.RunningVersion is { Length: 40 } v ? v[..7] : Updates.RunningVersion)</code>
                    @if (_updateCheck?.LatestVersion is { Length: 40 } latest)
                    {
                        <span> · latest: <code>@latest[..7]</code></span>
                    }
                </p>
                @if (!Updates.CanSelfUpdate)
                {
                    <p class="text-muted small mb-2">Self-update needs the Docker image build and the docker.sock mount — available on the NAS deployment.</p>
                }
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <button class="btn btn-sm btn-outline-secondary" disabled="@(_checkingUpdate || !Updates.CanSelfUpdate)"
                            @onclick="CheckUpdateAsync">@(_checkingUpdate ? "checking…" : "Check for updates")</button>
                    @if (_updateCheck is { Error: { } updateError })
                    {
                        <span class="text-danger small">@updateError</span>
                    }
                    else if (_updateCheck is { UpdateAvailable: true })
                    {
                        @if (_updating)
                        {
                            <span class="state-warn small">⏳ Updating — Labby will restart in ~30s, then reload this page.</span>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="TriggerUpdateAsync">⬆ Update now</button>
                        }
                    }
                    else if (_updateCheck is not null)
                    {
                        <span class="state-up small">✓ Up to date</span>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-header">📺 Kiosk / TV mode</div>
            <div class="card-body">
                <p class="text-muted small">
                    Full-screen rotation for a wall-mounted display — hides the nav and cycles the selected pages.
                    Press <kbd>Esc</kbd> on the kiosk device to exit.
                </p>
                <div class="d-flex flex-wrap align-items-center gap-3">
                    @foreach (var (path, label) in KioskPages)
                    {
                        <label class="form-check-label d-flex align-items-center gap-1">
                            <input type="checkbox" class="form-check-input"
                                   checked="@_kioskSelection.Contains(path)"
                                   @onchange="e => ToggleKioskPage(path, e.Value is true)" />
                            @label
                        </label>
                    }
                    <span class="d-flex align-items-center gap-1">
                        every <input type="number" class="form-control form-control-sm" style="width:5rem"
                                     min="5" @bind="_kioskSeconds" /> s
                    </span>
                    <button class="btn btn-sm btn-outline-primary" disabled="@(_kioskSelection.Count == 0)"
                            @onclick="StartKioskAsync">▶ Start kiosk</button>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-header">📜 Alert history</div>
            <div class="card-body p-0">
                @if (_alerts.Count == 0)
                {
                    <p class="text-muted p-3 mb-0">No alerts sent yet.</p>
                }
                else
                {
                    <table class="table table-sm table-striped align-middle mb-0">
                        <thead><tr><th style="width: 11rem">When</th><th>Message</th></tr></thead>
                        <tbody>
                            @foreach (var a in _alerts)
                            {
                                <tr>
                                    <td class="text-muted">@a.At.ToString("MMM d · HH:mm:ss")</td>
                                    <td>@a.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private static readonly (string Name, string Color)[] Themes =
    [
        ("green", "#2dd4a7"),
        ("amber", "#f0b429"),
        ("blue", "#4aa8ff"),
        ("purple", "#b98aff"),
    ];

    private static readonly (string Path, string Label)[] KioskPages =
    [
        ("", "Dashboard"),
        ("media", "Media"),
        ("weather", "Weather"),
        ("uptime", "Uptime"),
        ("network", "Network"),
        ("calendar", "Calendar"),
    ];

    private string _theme = "green";
    private bool _testSending;
    private bool _testSent;
    private readonly HashSet<string> _kioskSelection = ["", "media", "weather", "uptime"];
    private int _kioskSeconds = 20;
    private DateTimeOffset? _snoozedUntil;
    private bool _digestSending;
    private bool _checkingUpdate;
    private bool _updating;
    private UpdateService.UpdateCheck? _updateCheck;
    private IReadOnlyList<MetricsStore.AlertRecord> _alerts = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;
        _theme = await Js.InvokeAsync<string>("labbyTheme.get");
        _alerts = await Metrics.GetAlertsAsync();
        _snoozedUntil = await Alerts.GetSnoozedUntilAsync();
        StateHasChanged();
    }

    private async Task SetThemeAsync(string name)
    {
        _theme = name;
        await Js.InvokeVoidAsync("labbyTheme.set", name);
    }

    private void ToggleKioskPage(string path, bool selected)
    {
        if (selected)
            _kioskSelection.Add(path);
        else
            _kioskSelection.Remove(path);
    }

    private Task StartKioskAsync() =>
        Js.InvokeVoidAsync("labbyKiosk.start",
            KioskPages.Select(p => p.Path).Where(_kioskSelection.Contains).ToArray(),
            Math.Max(5, _kioskSeconds)).AsTask();

    private async Task SendDigestAsync()
    {
        _digestSending = true;
        try
        {
            await Alerts.SendAsync(await Digest.BuildDigestAsync());
            _alerts = await Metrics.GetAlertsAsync();
        }
        finally
        {
            _digestSending = false;
        }
    }

    private async Task CheckUpdateAsync()
    {
        _checkingUpdate = true;
        try
        {
            _updateCheck = await Updates.CheckAsync();
        }
        finally
        {
            _checkingUpdate = false;
        }
    }

    private async Task TriggerUpdateAsync()
    {
        _updating = true;
        try
        {
            await Updates.TriggerUpdateAsync();
        }
        catch (Exception ex)
        {
            _updateCheck = new UpdateService.UpdateCheck(true, _updateCheck?.LatestVersion, ex.GetBaseException().Message);
            _updating = false;
        }
    }

    private async Task SnoozeAsync(int hours)
    {
        await Alerts.SnoozeAsync(TimeSpan.FromHours(hours));
        _snoozedUntil = await Alerts.GetSnoozedUntilAsync();
    }

    private async Task ResumeAsync()
    {
        await Alerts.ResumeAsync();
        _snoozedUntil = null;
    }

    private async Task SendTestAsync()
    {
        _testSending = true;
        try
        {
            await Alerts.SendAsync($"🧪 Test alert from Labby — sent {DateTimeOffset.Now:HH:mm:ss}. If you can read this, alerts work.");
            _testSent = true;
            _alerts = await Metrics.GetAlertsAsync();
        }
        finally
        {
            _testSending = false;
        }
    }
}
