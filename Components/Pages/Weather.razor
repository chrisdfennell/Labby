@page "/weather"
@rendermode InteractiveServer
@inject AmbientWeatherClient WeatherClient
@inject WeatherHistoryService History
@inject WeatherAlertMonitor NwsAlerts
@inject IJSRuntime Js
@implements IAsyncDisposable

<PageTitle>Labby — Weather</PageTitle>

<h1 class="mb-1">🌤️ Weather Station</h1>
<p class="text-muted mb-4">
    @(_reading?.StationName ?? "Ambient Weather")
    @if (_reading is not null)
    {
        <span> — last report @_reading.ObservedAt.ToString("HH:mm:ss")</span>
    }
</p>

@foreach (var alert in NwsAlerts.Active)
{
    <div class="alert @(alert.Severity is "Extreme" or "Severe" ? "alert-danger" : "alert-warning")">
        <strong>⛈️ @alert.Event</strong> — @alert.Headline
        @if (alert.Ends is { } ends)
        {
            <span class="text-muted"> (until @ends.ToLocalTime().ToString("MMM d · HH:mm"))</span>
        }
    </div>
}

@if (!WeatherClient.IsConfigured)
{
    <div class="alert alert-warning">
        Ambient Weather is not configured. Create an API key + application key at
        <a href="https://ambientweather.net/account" target="_blank" rel="noreferrer">ambientweather.net/account</a>
        and set <code>AmbientWeather:ApiKey</code> and <code>AmbientWeather:ApplicationKey</code>.
    </div>
}
else
{
    @* Live readout — history below renders regardless, so a flaky API never hides logged data. *@
    @if (_reading is null)
    {
        <p class="text-muted">@(_error ?? "Loading…")</p>
    }
    else
    {
        <div class="row g-3">
            @foreach (var (label, value) in Readings())
            {
                <div class="col-6 col-md-4 col-xl-3">
                    <div class="card h-100">
                        <div class="card-body text-center">
                            <div class="text-muted small">@label</div>
                            <div class="fs-4 fw-semibold">@value</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (_reading is { StationLat: not null, StationLon: not null })
    {
        <div class="card mt-4">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span>🛰️ Radar — last 2h + short forecast</span>
                <span class="radar-controls">
                    <span id="radar-map-time" class="text-muted"></span>
                    <button type="button" id="radar-map-play" class="radar-play" title="Play/pause">⏸</button>
                </span>
            </div>
            <div class="card-body p-0">
                <div id="radar-map" class="radar-map"></div>
            </div>
        </div>
    }

    @if (_today is not null || _sun is not null)
    {
        <div class="row g-3 mb-3">
            @if (_today is { } today)
            {
            <div class="col-6 col-md">
                <div class="card h-100"><div class="card-body text-center py-2">
                    <div class="text-muted small">Today high / low</div>
                    <div class="fs-5 fw-semibold">@Deg(today.High) / @Deg(today.Low)</div>
                </div></div>
            </div>
            <div class="col-6 col-md">
                <div class="card h-100"><div class="card-body text-center py-2">
                    <div class="text-muted small">Peak gust</div>
                    <div class="fs-5 fw-semibold">@(today.PeakGust is { } g ? $"{g:0.#} mph" : "—") <span class="text-muted fs-6">@today.PeakGustDir</span></div>
                </div></div>
            </div>
            <div class="col-6 col-md">
                <div class="card h-100"><div class="card-body text-center py-2">
                    <div class="text-muted small">Rain today</div>
                    <div class="fs-5 fw-semibold">@Inches(today.Rain)</div>
                </div></div>
            </div>
            <div class="col-6 col-md">
                <div class="card h-100"><div class="card-body text-center py-2">
                    <div class="text-muted small">Max UV</div>
                    <div class="fs-5 fw-semibold">@(today.MaxUv?.ToString("0.#") ?? "—")</div>
                </div></div>
            </div>
            <div class="col-6 col-md">
                <div class="card h-100"><div class="card-body text-center py-2">
                    <div class="text-muted small">Peak solar</div>
                    <div class="fs-5 fw-semibold">@(today.MaxSolar is { } s ? $"{s:0} W/m²" : "—")</div>
                </div></div>
            </div>
            }
            @if (_sun is { Sunrise: not null, Sunset: not null } sun)
            {
                <div class="col-6 col-md">
                    <div class="card h-100"><div class="card-body text-center py-2">
                        <div class="text-muted small">🌅 @sun.Sunrise!.Value.ToString("HH:mm") · 🌇 @sun.Sunset!.Value.ToString("HH:mm")</div>
                        <div class="fs-5 fw-semibold">@(sun.DayLength is { } len ? $"{(int)len.TotalHours}h {len.Minutes}m of light" : "—")</div>
                    </div></div>
                </div>
            }
        </div>
    }

    <div class="d-flex align-items-center justify-content-between mt-4 mb-3">
        <h4 class="mb-0">History</h4>
        <div class="chart-range" role="group" aria-label="Time range">
            @foreach (var (hours, label) in Ranges)
            {
                <button class="btn btn-outline-primary @(_rangeHours == hours ? "active" : "")"
                        @onclick="() => SetRangeAsync(hours)">@label</button>
            }
        </div>
    </div>

    @if (_history.Count < 2)
    {
        <div class="alert alert-secondary">
            Not enough history yet — Labby logs a reading every 5 minutes while it runs, so charts appear after ~10 minutes.
        </div>
    }
    else
    {

        <div class="row g-3">
            <div class="col-lg-6">
                <LineChart Title="🌡️ Temperature (°F)" Unit="°F" WideRange="_rangeHours > 48"
                           Times="_times" Series="_tempSeries" />
            </div>
            <div class="col-lg-6">
                <LineChart Title="💨 Wind (mph) — arrows point downwind" Unit=" mph" WideRange="_rangeHours > 48"
                           Times="_times" Series="_windSeries"
                           Directions="_windDirections" PointLabels="_windLabels" />
            </div>
            <div class="col-lg-6">
                <LineChart Title="💧 Humidity (%)" Unit="%" TickFormat="0" WideRange="_rangeHours > 48"
                           Times="_times" Series="_humiditySeries" />
            </div>
            <div class="col-lg-6">
                <LineChart Title="🧭 Barometer (inHg)" Unit=" inHg" ValueFormat="0.00" TickFormat="0.00" WideRange="_rangeHours > 48"
                           Times="_times" Series="_pressureSeries" />
            </div>
            <div class="col-lg-6">
                <LineChart Title="🌧️ Rain (in, accumulates until midnight)" Unit=" in" ValueFormat="0.##" WideRange="_rangeHours > 48"
                           Times="_times" Series="_rainSeries" />
            </div>
            <div class="col-lg-6">
                <LineChart Title="☀️ Solar radiation (W/m²)" Unit=" W/m²" TickFormat="0" WideRange="_rangeHours > 48"
                           Times="_times" Series="_solarSeries" />
            </div>
            @if (_indoorSeries.Count > 0)
            {
                <div class="col-lg-6">
                    <LineChart Title="🏠 Indoor vs outdoor (°F)" Unit="°F" WideRange="_rangeHours > 48"
                               Times="_times" Series="_indoorSeries" />
                </div>
            }
        </div>

        <details class="mt-3">
            <summary class="text-muted small">Data table (@_history.Count readings)</summary>
            <div class="table-responsive mt-2" style="max-height: 24rem; overflow-y: auto;">
                <table class="table table-sm table-striped">
                    <thead>
                        <tr><th>Time</th><th>Temp</th><th>Feels like</th><th>Humidity</th><th>Barometer</th><th>Wind</th><th>Gust</th><th>Dir</th><th>UV</th><th>Rain</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var p in _history)
                        {
                            <tr>
                                <td>@p.At.ToString(_rangeHours > 48 ? "ddd HH:mm" : "HH:mm")</td>
                                <td>@(p.TempF?.ToString("0.#") ?? "—")</td>
                                <td>@(p.FeelsLikeF?.ToString("0.#") ?? "—")</td>
                                <td>@(p.HumidityPercent?.ToString("0") ?? "—")</td>
                                <td>@(p.BarometerInHg?.ToString("0.00") ?? "—")</td>
                                <td>@(p.WindSpeedMph?.ToString("0.#") ?? "—")</td>
                                <td>@(p.WindGustMph?.ToString("0.#") ?? "—")</td>
                                <td>@p.WindDirCompass</td>
                                <td>@(p.Uv?.ToString("0.#") ?? "—")</td>
                                <td>@(p.DailyRainIn?.ToString("0.##") ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </details>
    }
}

@code {
    private static readonly (int Hours, string Label)[] Ranges = [(24, "24h"), (48, "48h"), (168, "7d")];
    private const int MaxChartPoints = 360;

    private WeatherReading? _reading;
    private string? _error;
    private Timer? _refreshTimer;
    private int _rangeHours = 24;

    private IReadOnlyList<WeatherPoint> _history = [];
    private IReadOnlyList<DateTimeOffset> _times = [];
    private IReadOnlyList<(string, IReadOnlyList<double?>)> _tempSeries = [];
    private IReadOnlyList<(string, IReadOnlyList<double?>)> _windSeries = [];
    private IReadOnlyList<(string, IReadOnlyList<double?>)> _humiditySeries = [];
    private IReadOnlyList<(string, IReadOnlyList<double?>)> _pressureSeries = [];
    private IReadOnlyList<(string, IReadOnlyList<double?>)> _rainSeries = [];
    private IReadOnlyList<(string, IReadOnlyList<double?>)> _solarSeries = [];
    private IReadOnlyList<(string, IReadOnlyList<double?>)> _indoorSeries = [];
    private IReadOnlyList<double?> _windDirections = [];
    private IReadOnlyList<string?> _windLabels = [];
    private TodayStats? _today;
    private SolarMath.SunTimes? _sun;

    private sealed record TodayStats(double? High, double? Low, double? PeakGust, string PeakGustDir, double? Rain, double? MaxUv, double? MaxSolar);

    private bool _radarStarted;

    // History is a local SQLite read, so it can safely load during prerender and the
    // charts arrive with the first HTML. The live reading (external API) still waits
    // for the first interactive render so prerendering never blocks on it.
    protected override async Task OnInitializedAsync()
    {
        if (WeatherClient.IsConfigured)
            await LoadHistoryAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadAsync();
            StateHasChanged();
            _refreshTimer = new Timer(_ => _ = InvokeAsync(async () =>
            {
                await LoadAsync();
                StateHasChanged();
            }), null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
            return;
        }

        // Leaflet needs its container in the DOM, which only exists once coords are known.
        if (!_radarStarted && _reading is { StationLat: { } lat, StationLon: { } lon })
        {
            _radarStarted = true;
            await Js.InvokeVoidAsync("labbyRadar.init", "radar-map", lat, lon);
        }
    }

    private async Task LoadAsync()
    {
        if (!WeatherClient.IsConfigured)
            return;
        _reading = await WeatherClient.GetCurrentAsync();
        if (_reading is null)
            _error = "No data returned from Ambient Weather — check your keys.";
        if (_reading is { StationLat: { } lat, StationLon: { } lon })
            _sun = SolarMath.For(DateOnly.FromDateTime(DateTime.Today), lat, lon, TimeZoneInfo.Local);
        await LoadHistoryAsync();
    }

    private async Task SetRangeAsync(int hours)
    {
        _rangeHours = hours;
        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        _history = await History.GetSinceAsync(DateTimeOffset.Now.AddHours(-_rangeHours));
        var chartPoints = Downsample(_history);
        _times = chartPoints.Select(p => p.At).ToList();
        _tempSeries =
        [
            ("Temp", chartPoints.Select(p => p.TempF).ToList()),
            ("Feels like", chartPoints.Select(p => p.FeelsLikeF).ToList()),
        ];
        _windSeries =
        [
            ("Wind", chartPoints.Select(p => p.WindSpeedMph).ToList()),
            ("Gust", chartPoints.Select(p => p.WindGustMph).ToList()),
        ];
        _humiditySeries = [("Humidity", chartPoints.Select(p => p.HumidityPercent).ToList())];
        _pressureSeries = [("Barometer", chartPoints.Select(p => p.BarometerInHg).ToList())];
        _rainSeries = [("Rain", chartPoints.Select(p => p.DailyRainIn).ToList())];
        _solarSeries = [("Solar", chartPoints.Select(p => p.SolarRadiationWm2).ToList())];
        _indoorSeries = chartPoints.Any(p => p.IndoorTempF is not null)
            ? [("Outdoor", chartPoints.Select(p => p.TempF).ToList()), ("Indoor", chartPoints.Select(p => p.IndoorTempF).ToList())]
            : [];
        _windDirections = chartPoints.Select(p => p.WindDirDegrees).ToList();
        _windLabels = chartPoints
            .Select(p => p.WindDirDegrees is not null ? (string?)$"wind from {p.WindDirCompass}" : null)
            .ToList();

        var midnight = DateTimeOffset.Now.Date;
        var today = _history.Where(p => p.At >= midnight).ToList();
        if (today.Count > 0)
        {
            var peakGustPoint = today.Where(p => p.WindGustMph is not null).MaxBy(p => p.WindGustMph);
            _today = new TodayStats(
                High: today.Max(p => p.TempF),
                Low: today.Min(p => p.TempF),
                PeakGust: peakGustPoint?.WindGustMph,
                PeakGustDir: peakGustPoint?.WindDirCompass ?? "",
                Rain: today.Max(p => p.DailyRainIn),
                MaxUv: today.Max(p => p.Uv),
                MaxSolar: today.Max(p => p.SolarRadiationWm2));
        }
        else
        {
            _today = null;
        }
    }

    // Multi-day ranges hold thousands of samples; average them into buckets so the
    // SVG stays light without visibly changing the shape of the line.
    private static IReadOnlyList<WeatherPoint> Downsample(IReadOnlyList<WeatherPoint> points)
    {
        if (points.Count <= MaxChartPoints)
            return points;
        var bucketSize = (int)Math.Ceiling(points.Count / (double)MaxChartPoints);
        var result = new List<WeatherPoint>(MaxChartPoints);
        for (var i = 0; i < points.Count; i += bucketSize)
        {
            var bucket = points.Skip(i).Take(bucketSize).ToList();
            result.Add(new WeatherPoint
            {
                At = bucket[bucket.Count / 2].At,
                TempF = Avg(bucket, p => p.TempF),
                FeelsLikeF = Avg(bucket, p => p.FeelsLikeF),
                HumidityPercent = Avg(bucket, p => p.HumidityPercent),
                BarometerInHg = Avg(bucket, p => p.BarometerInHg),
                WindSpeedMph = Avg(bucket, p => p.WindSpeedMph),
                WindGustMph = Avg(bucket, p => p.WindGustMph),
                DailyRainIn = Avg(bucket, p => p.DailyRainIn),
                WindDirDegrees = CircularMeanDegrees(bucket),
                DewPointF = Avg(bucket, p => p.DewPointF),
                Uv = Avg(bucket, p => p.Uv),
                SolarRadiationWm2 = Avg(bucket, p => p.SolarRadiationWm2),
                IndoorTempF = Avg(bucket, p => p.IndoorTempF),
                IndoorHumidityPercent = Avg(bucket, p => p.IndoorHumidityPercent),
            });
        }
        return result;
    }

    private static double? Avg(List<WeatherPoint> bucket, Func<WeatherPoint, double?> selector)
    {
        var values = bucket.Select(selector).OfType<double>().ToList();
        return values.Count > 0 ? values.Average() : null;
    }

    // Bearings can't be averaged arithmetically (350° and 10° average to N, not S);
    // use the circular mean of the unit vectors.
    private static double? CircularMeanDegrees(List<WeatherPoint> bucket)
    {
        var radians = bucket.Select(p => p.WindDirDegrees).OfType<double>()
            .Select(d => d * Math.PI / 180).ToList();
        if (radians.Count == 0)
            return null;
        var sin = radians.Sum(Math.Sin);
        var cos = radians.Sum(Math.Cos);
        if (Math.Abs(sin) < 1e-9 && Math.Abs(cos) < 1e-9)
            return null;
        return (Math.Atan2(sin, cos) * 180 / Math.PI + 360) % 360;
    }

    private IEnumerable<(string Label, string Value)> Readings()
    {
        var r = _reading!;
        yield return ("Temperature", Deg(r.TempF));
        yield return ("Feels like", Deg(r.FeelsLikeF));
        yield return ("Dew point", Deg(r.DewPointF));
        yield return ("Humidity", Pct(r.HumidityPercent));
        yield return ("Wind", r.WindSpeedMph is { } w ? $"{w:0.#} mph {r.WindDirCompass}" : "—");
        yield return ("Wind gust", r.WindGustMph is { } g ? $"{g:0.#} mph" : "—");
        yield return ("Rain (hour)", Inches(r.HourlyRainIn));
        yield return ("Rain (today)", Inches(r.DailyRainIn));
        yield return ("Barometer", r.BarometerInHg is { } b ? $"{b:0.00} inHg" : "—");
        yield return ("UV index", r.Uv?.ToString("0.#") ?? "—");
        yield return ("Solar", r.SolarRadiationWm2 is { } s ? $"{s:0} W/m²" : "—");
        yield return ("Indoor", r.IndoorTempF is { } t ? $"{t:0.#}°F / {Pct(r.IndoorHumidityPercent)}" : "—");
    }

    private static string Deg(double? value) => value is { } v ? $"{v:0.#}°F" : "—";
    private static string Pct(double? value) => value is { } v ? $"{v:0}%" : "—";
    private static string Inches(double? value) => value is { } v ? $"{v:0.##} in" : "—";

    public async ValueTask DisposeAsync()
    {
        _refreshTimer?.Dispose();
        try
        {
            await Js.InvokeVoidAsync("labbyRadar.destroy");
        }
        catch (Exception)
        {
            // Circuit already gone — nothing to clean up client-side.
        }
    }
}
