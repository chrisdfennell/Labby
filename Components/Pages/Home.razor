@page "/"
@using System.Text
@rendermode InteractiveServer
@inject ServiceHealthMonitor Health
@inject AmbientWeatherClient Weather
@inject QnapClient Qnap
@inject MediaHub Media
@inject WakeOnLanService Wol
@inject MinerClient Miners
@implements IDisposable

<PageTitle>Labby — Dashboard</PageTitle>

<h1 class="mb-4">🏠 Home Lab</h1>

<div class="row g-3 mb-4">
    <div class="@(Media.AnyConfigured ? "col-lg-5 col-md-6" : "col-md-7")">
        <div class="card h-100">
            <div class="card-header">🌤️ Weather @(_weather?.StationName is { } n ? $"— {n}" : "")</div>
            <div class="card-body">
                @if (_weather is null)
                {
                    <span class="text-muted">@(_weatherError ?? "Loading…")</span>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-4 align-items-center">
                        <div>
                            <div class="fs-1 fw-bold">@(_weather.TempF?.ToString("0.#") ?? "—")°F</div>
                            <div class="text-muted">feels like @(_weather.FeelsLikeF?.ToString("0.#") ?? "—")°F</div>
                        </div>
                        <div>
                            <div>💧 @(_weather.HumidityPercent?.ToString("0") ?? "—")% humidity</div>
                            <div>💨 @(_weather.WindSpeedMph?.ToString("0.#") ?? "—") mph @_weather.WindDirCompass</div>
                            <div>🌧️ @(_weather.DailyRainIn?.ToString("0.##") ?? "—") in today</div>
                        </div>
                        <div class="ms-auto text-end text-muted small">
                            <a href="weather">full station →</a><br />
                            updated @_weather.ObservedAt.ToString("HH:mm")
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="@(Media.AnyConfigured ? "col-lg-4 col-md-6" : "col-md-5")">
        <div class="card h-100">
            <div class="card-header">💾 NAS @(_nas?.ServerName ?? "")</div>
            <div class="card-body">
                @if (_nas is null)
                {
                    <span class="text-muted">@(_nasError ?? "Loading…")</span>
                }
                else
                {
                    <div>CPU: <strong>@(_nas.CpuUsagePercent?.ToString("0.#") ?? "—")%</strong></div>
                    <div>RAM: <strong>@(_nas.UsedMemoryPercent?.ToString("0.#") ?? "—")%</strong> used</div>
                    <div>Uptime: <strong>@Format.Uptime(_nas.Uptime)</strong></div>
                    <a href="storage" class="small">storage details →</a>
                }
            </div>
        </div>
    </div>
    @if (Media.AnyConfigured)
    {
        <div class="col-lg-3 col-md-12">
            <div class="card h-100">
                <div class="card-header">🎬 Media</div>
                <div class="card-body">
                    @if (_streams is null && _downloads is null && _pendingRequests is null)
                    {
                        <span class="text-muted">Loading…</span>
                    }
                    else
                    {
                        @if (_streams is { } streams)
                        {
                            <div>▶ <strong>@streams</strong> streaming</div>
                        }
                        @if (_downloads is { } speed)
                        {
                            <div>⬇ <strong>@Format.Bytes(speed)/s</strong></div>
                        }
                        @if (_pendingRequests is { } pending)
                        {
                            <div>🎟 <strong>@pending</strong> pending</div>
                        }
                        <a href="media" class="small">media →</a>
                    }
                </div>
            </div>
        </div>
    }
</div>

<h4 class="mb-3">Services</h4>
@if (_services.Count == 0)
{
    <div class="alert alert-secondary">
        No services configured yet — add tiles under <code>Dashboard:Services</code> in <code>appsettings.json</code>.
    </div>
}
<div class="row g-3">
    @foreach (var s in _services)
    {
        <div class="col-sm-6 col-lg-4 col-xxl-3">
            <div class="card service-tile h-100">
                <a href="@s.Url" target="_blank" rel="noreferrer" class="text-decoration-none service-tile-link">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="fs-2">@s.Icon</div>
                        <div class="flex-grow-1">
                            <div class="fw-semibold">@s.Name</div>
                            <div class="text-muted small">@(s.Description ?? s.Url)</div>
                        </div>
                        <div class="text-end">
                            @if (s.IsUp is null)
                            {
                                <span class="status-dot pending" title="Waiting for first check"></span>
                            }
                            else if (s.IsUp == true)
                            {
                                <span class="status-dot up" title="Up"></span>
                                <div class="text-muted small">@(s.LatencyMs)ms</div>
                            }
                            else
                            {
                                <span class="status-dot down" title="@s.Error"></span>
                            }
                        </div>
                    </div>
                </a>
                @if (s.History.Count > 0)
                {
                    <div class="card-footer service-tile-footer">
                        <svg class="sparkline" viewBox="0 0 120 24" preserveAspectRatio="none" role="img"
                             aria-label="Latency over the last hour"><title>Latency, last hour</title>@RenderSparkline(s.History)</svg>
                        <span class="text-muted">@(s.UptimePercent?.ToString("0.#"))% up</span>
                        @if (s.StateSince is { } since)
                        {
                            <span class="@(s.IsUp == true ? "state-up" : "state-down")">
                                @(s.IsUp == true ? "up" : "down") @Format.ShortDuration(DateTimeOffset.Now - since)
                            </span>
                        }
                        @if (s.IsUp == false && !string.IsNullOrWhiteSpace(s.Mac))
                        {
                            <button type="button" class="wake-btn" title="Send Wake-on-LAN to @s.Mac"
                                    @onclick="() => WakeAsync(s)" disabled="@(_woken.Contains(s.Name))">
                                @(_woken.Contains(s.Name) ? "⚡ sent" : "⚡ wake")
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@if (Miners.AnyConfigured)
{
    <h4 class="mb-3 mt-4">⛏️ Miners</h4>
    <div class="row g-3">
        @foreach (var m in _miners)
        {
            <div class="col-sm-6 col-lg-4 col-xxl-3">
                <div class="card h-100">
                    <a href="@m.Url" target="_blank" rel="noreferrer" class="text-decoration-none service-tile-link">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-baseline gap-2">
                                <span class="fw-semibold">@m.Name</span>
                                @if (m.Error is not null)
                                {
                                    <span class="status-dot down" title="@m.Error"></span>
                                }
                                else
                                {
                                    <span class="miner-hashrate">@m.HashRateDisplay</span>
                                }
                            </div>
                            @if (m.Error is not null)
                            {
                                <div class="text-danger small">@m.Error</div>
                            }
                            else
                            {
                                <div class="text-muted small">@m.Host · @m.Pool</div>
                                <div class="miner-stats">
                                    <span title="Shares accepted / rejected">✔ @m.Accepted<span class="text-muted">/@m.Rejected</span></span>
                                    <span title="Best difficulty this session / ever">🏆 @(m.BestDiffSession ?? "—") <span class="text-muted">/ @(m.BestDiffEver ?? "—")</span></span>
                                    <span title="Uptime">⏱ @Format.Uptime(m.Uptime)</span>
                                    <span title="Wi-Fi signal">📶 @(m.RssiDbm?.ToString("0") ?? "—") dBm</span>
                                </div>
                            }
                        </div>
                    </a>
                </div>
            </div>
        }
        @if (_miners.Count == 0)
        {
            <div class="col-12"><span class="text-muted">Loading…</span></div>
        }
    </div>
}

@code {
    private IReadOnlyList<ServiceStatus> _services = [];
    private WeatherReading? _weather;
    private NasSystemInfo? _nas;
    private string? _weatherError;
    private string? _nasError;
    private int? _streams;
    private long? _downloads;
    private int? _pendingRequests;
    private IReadOnlyList<MinerStatus> _miners = [];
    private readonly HashSet<string> _woken = [];
    private Timer? _refreshTimer;

    protected override void OnInitialized()
    {
        _services = Health.Snapshot;
        Health.Changed += OnHealthChanged;
    }

    // Data loads after first render so prerendering never blocks on a slow/unreachable NAS.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;
        await LoadCardsAsync();
        StateHasChanged();
        _refreshTimer = new Timer(_ => _ = InvokeAsync(async () =>
        {
            await LoadCardsAsync();
            StateHasChanged();
        }), null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
    }

    // Cards load independently so one failing doesn't blank the others.
    private Task LoadCardsAsync() => Task.WhenAll(LoadWeatherAsync(), LoadNasAsync(), LoadMediaAsync(), LoadMinersAsync());

    private async Task LoadMinersAsync()
    {
        if (Miners.AnyConfigured)
            _miners = await Miners.GetStatusAsync();
    }

    private async Task LoadMediaAsync()
    {
        try
        {
            if (Media.TautulliConfigured)
                _streams = (await Media.GetNowPlayingAsync()).Sessions.Count;
            if (Media.DownloadsConfigured)
                _downloads = (await Media.GetDownloadsAsync()).DownloadBps;
            if (Media.OverseerrConfigured)
                _pendingRequests = (await Media.GetRequestsAsync()).Requests.Count;
        }
        catch (Exception)
        {
            // Card is a glance, not a monitor — details and errors live on /media.
        }
    }

    private async Task WakeAsync(ServiceStatus service)
    {
        if (service.Mac is { } mac && await Wol.WakeAsync(mac))
            _woken.Add(service.Name);
    }

    private async Task LoadWeatherAsync()
    {
        if (!Weather.IsConfigured)
        {
            _weatherError = "Not configured — set AmbientWeather:ApiKey and ApplicationKey.";
            return;
        }
        _weather = await Weather.GetCurrentAsync();
        if (_weather is null)
            _weatherError = "No data from Ambient Weather.";
    }

    private async Task LoadNasAsync()
    {
        if (!Qnap.IsConfigured)
        {
            _nasError = "Not configured — set Qnap:Host, Username and Password.";
            return;
        }
        try
        {
            _nas = await Qnap.GetSystemInfoAsync();
        }
        catch (Exception ex)
        {
            _nasError = ex.GetBaseException().Message;
        }
    }

    private void OnHealthChanged()
    {
        _services = Health.Snapshot;
        // A service that recovered can be woken again next time it goes down.
        _woken.RemoveWhere(name => _services.FirstOrDefault(s => s.Name == name)?.IsUp == true);
        _ = InvokeAsync(StateHasChanged);
    }

    // One 1-unit-wide bar per probe, newest at the right edge. Up = green, height scaled
    // to the slowest recent response; down = full-height red. Invariant formatting keeps
    // SVG coordinates valid regardless of server culture.
    private static MarkupString RenderSparkline(IReadOnlyList<ProbeSample> history)
    {
        var max = Math.Max(1, history.Max(p => p.LatencyMs ?? 0));
        var sb = new StringBuilder();
        for (var i = 0; i < history.Count; i++)
        {
            var p = history[i];
            var h = p.Up ? Math.Max(2.0, p.LatencyMs.GetValueOrDefault() * 20.0 / max) : 24.0;
            sb.Append(FormattableString.Invariant(
                $"""<rect x="{120 - (history.Count - i)}" y="{24 - h:0.##}" width="1" height="{h:0.##}" class="{(p.Up ? "spark-up" : "spark-down")}"/>"""));
        }
        return new MarkupString(sb.ToString());
    }

    public void Dispose()
    {
        Health.Changed -= OnHealthChanged;
        _refreshTimer?.Dispose();
    }
}
