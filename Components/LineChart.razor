@using System.Globalization
@using System.Text
@using System.Text.Json

@* Server-rendered SVG line chart. Hover crosshair + tooltip live in wwwroot/charts.js,
   which reads the data-chart JSON this component emits. *@

<div class="card h-100">
    <div class="card-header d-flex align-items-center justify-content-between gap-2">
        <span>@Title</span>
        @if (Series.Count > 1)
        {
            <span class="chart-legend">
                @for (var i = 0; i < Series.Count; i++)
                {
                    <span class="chart-key"><span class="chart-key-line" style="background:@Palette[i]"></span>@Series[i].Name</span>
                }
            </span>
        }
    </div>
    <div class="card-body p-2">
        @if (Times.Count < 2)
        {
            <div class="text-muted small p-3">No history yet — a sample is logged every 5 minutes.</div>
        }
        else
        {
            <div class="lab-chart" data-chart="@MetaJson()">
                <svg viewBox="0 0 @W @H" role="img" aria-label="@Title">
                    @* gridlines + y ticks *@
                    @foreach (var tick in _ticks)
                    {
                        <line x1="@Inv(PadL)" x2="@Inv(W - PadR)" y1="@Inv(Y(tick))" y2="@Inv(Y(tick))" class="chart-grid" />
                        @SvgText(PadL - 6, Y(tick) + 3, "chart-tick", "end", tick.ToString(TickFormat))
                    }
                    @* x time labels *@
                    @foreach (var (index, label) in XLabels())
                    {
                        @SvgText(X(index), H - 6, "chart-tick", "middle", label)
                    }
                    @* series lines (gaps where data is null) *@
                    @for (var s = 0; s < Series.Count; s++)
                    {
                        foreach (var run in Runs(s))
                        {
                            <polyline points="@run" fill="none" stroke="@Palette[s]" stroke-width="2"
                                      stroke-linejoin="round" stroke-linecap="round" />
                        }
                    }
                    @* end dots + selective end labels *@
                    @foreach (var (s, index, value) in EndPoints())
                    {
                        <circle cx="@Inv(X(index))" cy="@Inv(Y(value))" r="4" fill="@Palette[s]" class="chart-dot" />
                        @if (_labelled.Contains(s))
                        {
                            @SvgText(X(index) + 8, Y(value) + 3.5, "chart-endlabel", "start", value.ToString(ValueFormat))
                        }
                    }
                    @* hover layer targets, driven by charts.js *@
                    <line class="chart-cursor" x1="0" x2="0" y1="@Inv(PadT)" y2="@Inv(H - PadB)" />
                    @for (var s = 0; s < Series.Count; s++)
                    {
                        <circle class="chart-cursor-dot" r="4" fill="@Palette[s]" />
                    }
                </svg>
            </div>
        }
    </div>
</div>

@code {
    // Validated against the card surface (#101823) with the dataviz palette checks:
    // lightness band, chroma, CVD separation, and 3:1 contrast all pass.
    private static readonly string[] Palette = ["#12a37e", "#bb8410"];

    private const double W = 600, H = 220, PadL = 44, PadR = 60, PadT = 12, PadB = 22;

    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter, EditorRequired] public IReadOnlyList<DateTimeOffset> Times { get; set; } = [];
    /// <summary>Up to two series; values align with <see cref="Times"/> and may contain gaps.</summary>
    [Parameter, EditorRequired] public IReadOnlyList<(string Name, IReadOnlyList<double?> Values)> Series { get; set; } = [];
    [Parameter] public string Unit { get; set; } = "";
    [Parameter] public string ValueFormat { get; set; } = "0.#";
    [Parameter] public string TickFormat { get; set; } = "0.#";
    /// <summary>Show weekday+hour instead of hour:minute on the x axis (for multi-day ranges).</summary>
    [Parameter] public bool WideRange { get; set; }

    private double _min, _max;
    private List<double> _ticks = [];
    private HashSet<int> _labelled = [];

    protected override void OnParametersSet()
    {
        var values = Series.SelectMany(s => s.Values).OfType<double>().ToList();
        if (values.Count == 0)
            values = [0, 1];
        _min = values.Min();
        _max = values.Max();
        if (Math.Abs(_max - _min) < 0.001)
        {
            _min -= 1;
            _max += 1;
        }
        var pad = (_max - _min) * 0.08;
        _min -= pad;
        _max += pad;
        _ticks = NiceTicks(_min, _max);
        _labelled = PickLabelledSeries();
    }

    private double X(int i) => PadL + (W - PadL - PadR) * i / Math.Max(1, Times.Count - 1);
    private double Y(double v) => H - PadB - (v - _min) / (_max - _min) * (H - PadT - PadB);

    private static string Inv(double v) => v.ToString("0.##", CultureInfo.InvariantCulture);

    // Razor reserves the <text> tag, so SVG text elements are emitted as markup.
    private static MarkupString SvgText(double x, double y, string cls, string anchor, string content) =>
        new($"<text x=\"{Inv(x)}\" y=\"{Inv(y)}\" class=\"{cls}\" text-anchor=\"{anchor}\">{System.Net.WebUtility.HtmlEncode(content)}</text>");

    private IEnumerable<string> Runs(int seriesIndex)
    {
        var sb = new StringBuilder();
        var any = false;
        for (var i = 0; i < Times.Count; i++)
        {
            if (Series[seriesIndex].Values[i] is { } v)
            {
                if (any)
                    sb.Append(' ');
                sb.Append(Inv(X(i))).Append(',').Append(Inv(Y(v)));
                any = true;
            }
            else if (any)
            {
                yield return sb.ToString();
                sb.Clear();
                any = false;
            }
        }
        if (any)
            yield return sb.ToString();
    }

    private IEnumerable<(int Series, int Index, double Value)> EndPoints()
    {
        for (var s = 0; s < Series.Count; s++)
        {
            for (var i = Times.Count - 1; i >= 0; i--)
            {
                if (Series[s].Values[i] is { } v)
                {
                    yield return (s, i, v);
                    break;
                }
            }
        }
    }

    // Label every line end unless two ends collide; then only the first keeps its
    // label and the legend + tooltip carry the other (never stack nudged labels).
    private HashSet<int> PickLabelledSeries()
    {
        var ends = EndPoints().ToList();
        var picked = new HashSet<int>();
        foreach (var (s, _, v) in ends)
        {
            if (ends.Any(e => picked.Contains(e.Series) && Math.Abs(Y(e.Value) - Y(v)) < 13))
                continue;
            picked.Add(s);
        }
        return picked;
    }

    private IEnumerable<(int Index, string Label)> XLabels()
    {
        if (Times.Count < 2)
            yield break;
        var format = WideRange ? "ddd HH:mm" : "HH:mm";
        foreach (var fraction in (double[])[0.02, 0.35, 0.68, 0.98])
        {
            var i = (int)Math.Round(fraction * (Times.Count - 1));
            yield return (i, Times[i].ToString(format));
        }
    }

    private static List<double> NiceTicks(double min, double max)
    {
        var raw = (max - min) / 4;
        var mag = Math.Pow(10, Math.Floor(Math.Log10(raw)));
        var step = (raw / mag) switch { < 1.5 => 1, < 3.5 => 2, < 7.5 => 5, _ => 10 } * mag;
        var ticks = new List<double>();
        for (var t = Math.Ceiling(min / step) * step; t <= max; t += step)
        {
            var v = Math.Round(t, 6);
            ticks.Add(v == 0 ? 0 : v); // never render "-0"
        }
        return ticks;
    }

    private string MetaJson() => JsonSerializer.Serialize(new
    {
        u = Unit,
        s = Series.Select(x => x.Name),
        c = Palette[..Series.Count],
        t = Times.Select(x => x.ToUnixTimeMilliseconds()),
        v = Series.Select(x => x.Values),
        w = W, h = H, l = PadL, r = PadR, pt = PadT, pb = PadB,
        min = _min, max = _max,
        wide = WideRange,
    });
}
